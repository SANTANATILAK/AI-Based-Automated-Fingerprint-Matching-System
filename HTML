<!DOCTYPE html>
<html>
<head>
<title>Fingerprint AI Login</title>
<link rel="stylesheet" href="/static/css/style.css">
</head>

<body>

<div class="login-box">

<h2>Crime Investigation System</h2>

<form method="POST">

<input type="text" name="username" placeholder="Username">

<input type="password" name="password" placeholder="Password">

<button type="submit">Login</button>

</form>

</div>

</body>
</html>
<!DOCTYPE html>
<html>
<head>

<title>Fingerprint Matcher</title>

<link rel="stylesheet" href="/static/css/style.css">

</head>

<body>

<h1>AI Fingerprint Matching</h1>

<form action="/predict" method="POST" enctype="multipart/form-data">

<input type="file" name="file" required>

<button type="submit">Match Fingerprint</button>

</form>

<a href="/history">Match History</a>

</body>
</html>

<!DOCTYPE html>
<html>

<head>

<title>Match Results</title>

</head>

<body>

<h2>Top Matches</h2>

<table border="1">

<tr>
<th>Name</th>
<th>Similarity Score</th>
</tr>

{% for fp, score in results %}

<tr>

<td>{{ fp.name }}</td>

<td>{{ score }}</td>

</tr>

{% endfor %}

</table>

<p>Processing Time: {{ elapsed }} seconds</p>

<a href="/">Try Another</a>

</body>

</html>

<h1>Admin Dashboard</h1>

<a href="/admin/add">Add Fingerprint</a>

<table border="1">

<tr>

<th>ID</th>
<th>Name</th>
<th>Address</th>
<th>Delete</th>

</tr>

{% for fp in fingerprints %}

<tr>

<td>{{ fp.id }}</td>
<td>{{ fp.name }}</td>
<td>{{ fp.address }}</td>

<td>

<a href="/admin/delete/{{ fp.id }}">Delete</a>

</td>

</tr>

{% endfor %}

</table>